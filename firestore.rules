rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leads
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - phone: string (required, 5-20 chars)
    //   - telegram: string (required, 2-50 chars)
    //   - createdAt: timestamp (required, server-set)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "yginshelk@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'phone', 'telegram', 'createdAt']) &&
             data.keys().hasOnly(['name', 'phone', 'telegram', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 20 &&
             data.telegram is string && data.telegram.size() >= 2 && data.telegram.size() <= 50 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /leads/{leadId} {
      // Anyone can submit a lead (public form)
      allow create: if isValidLead(request.resource.data) && 
                      request.resource.data.createdAt == request.time;
      
      // Only admins can read or manage leads
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
